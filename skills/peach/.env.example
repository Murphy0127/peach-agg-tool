# Copy this file to ~/.config/peach-agg-tool/.env and fill in your credentials:
#   mkdir -p ~/.config/peach-agg-tool
#   cp .env.example ~/.config/peach-agg-tool/.env

# OKX API Credentials (for quote --agg all, compare, dex-stats)
# Get credentials from: https://www.okx.com/account/my-api
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""
OKX_PROJECT_ID=""

# Peach Debug API Token (for debug command pool inspection)
PEACH_DEBUG_TOKEN=""
